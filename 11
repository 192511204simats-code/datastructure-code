#include <stdio.h>
#define MAX 5

int stack[MAX], top = -1;

void push()
{
    int x;
    if(top == MAX-1)
        printf("Stack Overflow\n");
    else
    {
        printf("Enter element: ");
        scanf("%d",&x);
        stack[++top] = x;
    }
}

void pop()
{
    if(top == -1)
        printf("Stack Underflow\n");
    else
        printf("Deleted element: %d\n", stack[top--]);
}

void peek()
{
    if(top == -1)
        printf("Stack Empty\n");
    else
        printf("Top element: %d\n", stack[top]);
}

int main()
{
    push();
    push();
    peek();
