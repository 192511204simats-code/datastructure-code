#include <stdio.h>

int main()
{
    int cost[10][10], visited[10];
    int n, i, j, min, a, b, u, v;
    int ne = 1, mincost = 0;

    printf("Enter number of vertices: ");
    scanf("%d",&n);

    printf("Enter cost matrix:\n");
    for(i=0;i<n;i++)
        for(j=0;j<n;j++)
        {
            scanf("%d",&cost[i][j]);
            if(cost[i][j] == 0)
                cost[i][j] = 999;
        }

    visited[0] = 1;

    printf("Edges of MST:\n");

    while(ne < n)
    {
        min = 999;

        for(i=0;i<n;i++)
        {
            for(j=0;j<n;j++)
            {
                if(cost[i][j] < min)
                {
                    if(visited[i] != 0)
                    {
                        min = cost[i][j];
                        a = u = i;
                        b = v = j;
                    }
                }
            }
        }

        if(visited[u] == 0 || visited[v] == 0)
        {
            printf("%d -> %d = %d\n", a, b, min);
            mincost += min;
            visited[b] = 1;
            ne++;
        }

        cost[a][b] = cost[b][a] = 999;
    }

    printf("Minimum Cost = %d", mincost);

    return 0;
}
