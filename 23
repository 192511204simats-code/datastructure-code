#include <stdio.h>

int main()
{
    int cost[10][10], dist[10], visited[10];
    int n, i, j, start, min, next;

    printf("Enter number of vertices: ");
    scanf("%d",&n);

    printf("Enter cost matrix:\n");
    for(i=0;i<n;i++)
        for(j=0;j<n;j++)
            scanf("%d",&cost[i][j]);

    printf("Enter source vertex: ");
    scanf("%d",&start);

    for(i=0;i<n;i++)
    {
        dist[i] = cost[start][i];
        visited[i] = 0;
    }

    visited[start] = 1;

    for(i=1;i<n;i++)
    {
        min = 999;

        for(j=0;j<n;j++)
        {
            if(!visited[j] && dist[j] < min)
            {
                min = dist[j];
                next = j;
            }
        }

        visited[next] = 1;

        for(j=0;j<n;j++)
        {
            if(!visited[j] && dist[next] + cost[next][j] < dist[j])
                dist[j] = dist[next] + cost[next][j];
        }
    }

    printf("Shortest Distances:\n");
    for(i=0;i<n;i++)
        printf("%d -> %d = %d\n", start, i, dist[i]);

    return 0;
}
